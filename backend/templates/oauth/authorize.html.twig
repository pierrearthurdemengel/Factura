{% extends 'base.html.twig' %}

{% block title %}Autoriser {{ client.name }} — Ma Facture Pro{% endblock %}

{% block stylesheets %}
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #f8f9fa;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding: 1rem;
    }
    .card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        max-width: 420px;
        width: 100%;
        padding: 2rem;
    }
    .logo {
        text-align: center;
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 1.5rem;
    }
    .logo span { color: #4f46e5; }
    h1 {
        font-size: 1.1rem;
        color: #374151;
        text-align: center;
        margin-bottom: 0.5rem;
    }
    .client-name {
        font-weight: 700;
        color: #1a1a1a;
    }
    .description {
        text-align: center;
        color: #6b7280;
        font-size: 0.875rem;
        margin-bottom: 1.5rem;
    }
    .scopes {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1.5rem;
    }
    .scopes-title {
        font-size: 0.8rem;
        font-weight: 600;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
    }
    .scope-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.25rem 0;
        font-size: 0.875rem;
        color: #4b5563;
    }
    .scope-icon { color: #10b981; }
    .actions {
        display: flex;
        gap: 0.75rem;
    }
    .btn {
        flex: 1;
        padding: 0.75rem;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: background 0.2s;
    }
    .btn-deny {
        background: #f3f4f6;
        color: #374151;
    }
    .btn-deny:hover { background: #e5e7eb; }
    .btn-allow {
        background: #4f46e5;
        color: white;
    }
    .btn-allow:hover { background: #4338ca; }
</style>
{% endblock %}

{% block body %}
<div class="card">
    <div class="logo">Ma Facture <span>Pro</span></div>

    <h1><span class="client-name">{{ client.name }}</span> demande l'acces a votre compte</h1>
    <p class="description">Cette application pourra agir en votre nom sur Ma Facture Pro.</p>

    <div class="scopes">
        <div class="scopes-title">Permissions demandees</div>
        {% set scope_labels = {
            'invoices:read': 'Consulter vos factures',
            'invoices:write': 'Creer et gerer vos factures',
            'clients:read': 'Consulter vos clients',
            'clients:write': 'Creer et modifier vos clients',
            'company:read': 'Consulter les informations de votre entreprise',
            'stats:read': 'Consulter vos statistiques de facturation',
        } %}
        {% for s in scope|split(' ') %}
            {% if s in scope_labels|keys %}
            <div class="scope-item">
                <span class="scope-icon">✓</span>
                {{ scope_labels[s] }}
            </div>
            {% endif %}
        {% endfor %}
    </div>

    <form method="post" action="{{ path('oauth_authorize') }}?{{ query_string }}">
        <div class="actions">
            <button type="submit" name="decision" value="deny" class="btn btn-deny">Refuser</button>
            <button type="submit" name="decision" value="allow" class="btn btn-allow">Autoriser</button>
        </div>
    </form>
</div>
{% endblock %}
